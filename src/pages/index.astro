---
import Base from '../layouts/Base.astro';
import TimelineItem from '../components/TimelineItem.astro';
import CatalogCard from '../components/CatalogCard.astro';
import type { TimelineEntry } from '../components/TimelineItem.astro';
import { getCollection } from 'astro:content';

const feed: TimelineEntry[] = [];

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '').slice(0, 60);
}

const usedSlugs = new Set<string>();
function uniqueSlug(base: string, prefix: string): string {
  let slug = prefix ? `${prefix}-${slugify(base)}` : slugify(base);
  let i = 2;
  while (usedSlugs.has(slug)) { slug = `${prefix}-${slugify(base)}-${i++}`; }
  usedSlugs.add(slug);
  return slug;
}

function stripMarkdown(md: string): string {
  return md
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/(\*\*|__)(.*?)\1/g, '$2')
    .replace(/(\*|_)(.*?)\1/g, '$2')
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    .replace(/^[-*>]\s+/gm, '')
    .replace(/\n{2,}/g, '\n')
    .trim();
}

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
for (const p of allPosts) {
  const bodyText = (p as any).body ? stripMarkdown((p as any).body).slice(0, 800) : undefined;
  feed.push({
    title: p.data.title, description: p.data.description,
    date: p.data.date, world: p.data.world, source: 'post',
    url: `/blog/${p.id}/`, external: false, image: p.data.cover,
    htmlContent: bodyText,
    meta: { slideId: uniqueSlug(p.data.title, '') },
  });
}

const ytVideos = await getCollection('youtube');
for (const v of ytVideos) {
  feed.push({
    title: v.data.caption, date: v.data.date, world: 'film',
    source: 'youtube', url: `https://youtube.com/watch?v=${v.data.videoId}`,
    external: true, image: v.data.thumbnail,
    meta: { videoId: v.data.videoId, slideId: uniqueSlug(v.data.caption, 'yt') },
  });
}

const photoEntries = await getCollection('photos');
for (const c of photoEntries) {
  feed.push({
    title: c.data.caption, date: c.data.date, world: 'travel',
    source: 'photo', url: `/photo/${c.id}/`, external: false, image: c.data.image,
    meta: { slideId: uniqueSlug(c.data.caption, 'img') },
  });
}

const lbEntries = await getCollection('letterboxd');
for (const lb of lbEntries) {
  feed.push({
    title: lb.data.filmTitle, description: lb.data.review,
    date: lb.data.date, world: 'film', source: 'letterboxd',
    url: lb.data.url, external: true, image: lb.data.poster,
    meta: { rating: lb.data.rating, slideId: uniqueSlug(lb.data.filmTitle, 'film') },
  });
}

const ssEntries = await getCollection('substackFeed');
for (const s of ssEntries) {
  feed.push({
    title: s.data.title, description: s.data.excerpt,
    date: s.data.date, world: 'writing', source: 'substack',
    url: s.data.url, external: true, image: s.data.image,
    meta: { slideId: uniqueSlug(s.data.title, 'ss') },
  });
}

const mdEntries = await getCollection('mediumFeed');
for (const m of mdEntries) {
  feed.push({
    title: m.data.title, description: m.data.excerpt,
    date: m.data.date, world: 'writing', source: 'medium',
    url: m.data.url, external: true, image: m.data.image,
    meta: { slideId: uniqueSlug(m.data.title, 'md') },
  });
}

const ghRepos = await getCollection('github');
for (const r of ghRepos) {
  feed.push({
    title: r.data.name, description: r.data.description,
    date: r.data.date, world: 'tech', source: 'github',
    url: r.data.url, external: true, image: r.data.image,
    meta: { language: r.data.language, stars: r.data.stars, slideId: uniqueSlug(r.data.name, 'gh') },
  });
}

const scTracks = await getCollection('soundcloud');
for (const t of scTracks) {
  feed.push({
    title: t.data.trackTitle, date: t.data.date, world: 'music',
    source: 'soundcloud', url: t.data.url, external: true,
    image: t.data.artwork,
    meta: { slideId: uniqueSlug(t.data.trackTitle, 'sc'), embedUrl: t.data.embedUrl, evergreen: true },
  });
}

const spEntries = await getCollection('spotify');
for (const sp of spEntries) {
  feed.push({
    title: sp.data.name, date: new Date('2000-01-01'), world: 'music',
    source: 'spotify', url: sp.data.url, external: true,
    image: sp.data.image,
    meta: { embedUrl: sp.data.embedUrl, slideId: uniqueSlug(sp.data.name, 'sp'), evergreen: true },
  });
}

const galEntries = await getCollection('gallery');
for (const g of galEntries) {
  feed.push({
    title: g.data.title, description: g.data.location,
    date: g.data.date, world: 'travel', source: 'gallery',
    url: `/gallery/${g.id}/`, external: false, image: g.data.cover,
    meta: { photos: g.data.photos, slideId: uniqueSlug(g.data.title, 'gal') },
  });
}

const UNSPLASH_KEY = import.meta.env.UNSPLASH_ACCESS_KEY;
const worldQueries: Record<string, string> = {
  tech: 'technology code programming', film: 'cinema film camera',
  music: 'music instruments concert', writing: 'books writing journal',
  travel: 'travel landscape adventure',
};

const needsByWorld: Record<string, TimelineEntry[]> = {};
for (const item of feed) {
  if (!item.image) (needsByWorld[item.world] ??= []).push(item);
}

if (UNSPLASH_KEY && Object.keys(needsByWorld).length) {
  const fetches = Object.entries(needsByWorld).map(async ([world, items]) => {
    try {
      const count = Math.min(items.length, 30);
      const res = await fetch(
        `https://api.unsplash.com/photos/random?query=${encodeURIComponent(worldQueries[world] || world)}&count=${count}&orientation=landscape`,
        { headers: { Authorization: `Client-ID ${UNSPLASH_KEY}` } },
      );
      if (!res.ok) return;
      const photos: any[] = await res.json();
      items.forEach((item, i) => {
        const photo = photos[i % photos.length];
        item.image = `${photo.urls.raw}&w=1200&h=800&fit=crop&q=80`;
      });
    } catch { /* fall through to static fallback */ }
  });
  await Promise.all(fetches);
}

const staticFallback: Record<string, string[]> = {
  tech:    ['photo-1518770660439-4636190af475','photo-1461749280684-dccba630e2f6','photo-1488590528505-98d2b5aba04b','photo-1550751827-4bd374c3f58b','photo-1517694712202-14dd9538aa97','photo-1504639725590-34d0984388bd'],
  film:    ['photo-1485846234645-a62644f84728','photo-1478720568477-152d9b164e26','photo-1440404653325-ab127d49abc1','photo-1536440136628-849c177e76a1','photo-1489599849927-2ee91cede3ba','photo-1595769816263-9b910be24d5f'],
  music:   ['photo-1511379938547-c1f69419868d','photo-1493225457124-a3eb161ffa5f','photo-1514320291840-2e0a9bf2a9ae','photo-1510915361894-db8b60106cb1','photo-1459749411175-04bf5292ceea','photo-1470225620780-dba8ba36b745'],
  writing: ['photo-1455390582262-044cdead277a','photo-1457369804613-52c61a468e7d','photo-1471107340929-a87cd0f5b5f3','photo-1506880018603-83d5b814b5a6','photo-1432821596592-e2c18b78144f','photo-1516414447565-b14be0adf13e'],
  travel:  ['photo-1488646953014-85cb44e25828','photo-1469854523086-cc02fe5d8800','photo-1476514525535-07fb3b4ae5f1','photo-1507525428034-b723cf961d3e','photo-1502920917128-1aa500764cbd','photo-1500835556837-99ac94a94552'],
};
function titleHash(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}
for (const item of feed) {
  if (!item.image) {
    const pool = staticFallback[item.world] || staticFallback.tech;
    item.image = `https://images.unsplash.com/${pool[titleHash(item.title) % pool.length]}?w=1200&h=800&fit=crop&q=80`;
  }
}

feed.sort((a, b) => {
  const aEver = a.meta?.evergreen ? 1 : 0;
  const bEver = b.meta?.evergreen ? 1 : 0;
  if (aEver !== bEver) return aEver - bEver;
  return b.date.getTime() - a.date.getTime();
});
---

<Base isTimeline>
  <div class="timeline" id="timeline">
    {feed.map((item) => <TimelineItem item={item} />)}

    {feed.length === 0 && (
      <div class="tl-slide slide-empty-state">
        <p class="slide-empty">Nothing here yet.</p>
      </div>
    )}
  </div>

  <div class="catalog" id="catalog" style="display:none">
    <div class="catalog-grid" id="catalogGrid">
      {feed.map((item) => <CatalogCard item={item} />)}
    </div>
  </div>

  <div class="scrubber" id="scrubber">
    <div class="scrubber-track"></div>
    <div class="scrubber-thumb" id="scrubberThumb"></div>
    <div class="scrubber-label" id="scrubberLabel"></div>
  </div>
</Base>

<script>
  const timeline = document.getElementById('timeline');
  if (!timeline) throw new Error('missing timeline');

  // --- 1. Video Observer: load/unload iframe on snap ---
  const videoSlides = document.querySelectorAll<HTMLElement>('.slide-video');

  const ytHideTimers = new Map<HTMLElement, ReturnType<typeof setTimeout>>();

  const videoObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const el = entry.target as HTMLElement;
      const slide = el.closest('.tl-slide') as HTMLElement | null;
      const iframe = el.querySelector('iframe') as HTMLIFrameElement | null;
      if (!iframe || !slide) return;
      if (entry.isIntersecting) {
        if (!iframe.src) iframe.src = iframe.dataset.src || '';
        else iframe.contentWindow?.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
        const timer = setTimeout(() => slide.classList.add('yt-playing'), 3000);
        ytHideTimers.set(slide, timer);
      } else {
        iframe.contentWindow?.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
        clearTimeout(ytHideTimers.get(slide));
        slide.classList.remove('yt-playing');
      }
    });
  }, { root: timeline, threshold: 0.5 });

  document.querySelectorAll<HTMLElement>('.slide-youtube').forEach((slide) => {
    slide.addEventListener('click', () => {
      if (!slide.classList.contains('yt-playing')) return;
      slide.classList.remove('yt-playing');
      clearTimeout(ytHideTimers.get(slide));
      const timer = setTimeout(() => slide.classList.add('yt-playing'), 3000);
      ytHideTimers.set(slide, timer);
    });
  });

  videoSlides.forEach((v) => videoObserver.observe(v));

  document.querySelectorAll<HTMLButtonElement>('.slide-mute-btn').forEach((btn) => {
    let muted = true;
    btn.addEventListener('click', () => {
      const iframe = btn.closest('.tl-slide')?.querySelector('iframe') as HTMLIFrameElement | null;
      if (!iframe?.contentWindow) return;
      muted = !muted;
      iframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: muted ? 'mute' : 'unMute' }), '*');
      const iconM = btn.querySelector('.icon-muted') as HTMLElement;
      const iconU = btn.querySelector('.icon-unmuted') as HTMLElement;
      if (iconM) iconM.style.display = muted ? 'block' : 'none';
      if (iconU) iconU.style.display = muted ? 'none' : 'block';
      btn.setAttribute('aria-label', muted ? 'Unmute' : 'Mute');
    });
  });

  // --- 1b. Stop scroll-snap when user scrolls inline content ---
  document.querySelectorAll('.slide-prose, .slide-review, .slide-excerpt').forEach((el) => {
    el.addEventListener('wheel', (e) => { e.stopPropagation(); }, { passive: true });
    el.addEventListener('touchmove', (e) => { e.stopPropagation(); }, { passive: true });
  });

  // --- 1c. Inline gallery lightbox ---
  document.querySelectorAll('[data-gallery]').forEach((grid) => {
    const imgs = Array.from(grid.querySelectorAll('img'));
    imgs.forEach((img, idx) => {
      img.addEventListener('click', () => openLightbox(imgs.map(i => i.src), idx));
    });
  });

  function openLightbox(srcs: string[], startIdx: number) {
    let idx = startIdx;
    const lb = document.createElement('div');
    lb.className = 'lightbox';
    lb.innerHTML = `
      <button class="lightbox-close" aria-label="Close">&times;</button>
      <button class="lightbox-prev" aria-label="Previous">&lsaquo;</button>
      <img src="${srcs[idx]}" alt="Photo ${idx + 1} of ${srcs.length}">
      <button class="lightbox-next" aria-label="Next">&rsaquo;</button>
      <div class="lightbox-counter">${idx + 1} / ${srcs.length}</div>
    `;
    document.body.appendChild(lb);

    const imgEl = lb.querySelector('img')!;
    const counterEl = lb.querySelector('.lightbox-counter')!;
    const update = () => { imgEl.src = srcs[idx]; imgEl.alt = `Photo ${idx + 1} of ${srcs.length}`; counterEl.textContent = `${idx + 1} / ${srcs.length}`; };

    lb.querySelector('.lightbox-close')!.addEventListener('click', () => lb.remove());
    lb.querySelector('.lightbox-prev')!.addEventListener('click', () => { idx = (idx - 1 + srcs.length) % srcs.length; update(); });
    lb.querySelector('.lightbox-next')!.addEventListener('click', () => { idx = (idx + 1) % srcs.length; update(); });
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.remove(); });
    document.addEventListener('keydown', function handler(e) {
      if (e.key === 'Escape') { lb.remove(); document.removeEventListener('keydown', handler); }
      if (e.key === 'ArrowLeft') { idx = (idx - 1 + srcs.length) % srcs.length; update(); }
      if (e.key === 'ArrowRight') { idx = (idx + 1) % srcs.length; update(); }
    });
  }

  // --- 2. Shared World Tabs (filter both views) ---
  const worldTabs = document.querySelectorAll<HTMLButtonElement>('.catalog-tab');
  const slides = document.querySelectorAll<HTMLElement>('.tl-slide');
  const catalogCards = document.querySelectorAll<HTMLElement>('.catalog-card');
  let currentWorld = 'all';
  let currentView = 'timeline';

  function syncUrl() {
    const params = new URLSearchParams();
    if (currentView !== 'timeline') params.set('view', currentView);
    if (currentWorld !== 'all') params.set('world', currentWorld);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}${location.hash}` : `/${location.hash}`);
  }

  function applyWorldFilter(world: string) {
    currentWorld = world;
    slides.forEach((slide) => {
      slide.style.display = (world === 'all' || slide.dataset.world === world) ? '' : 'none';
    });
    catalogCards.forEach((card) => {
      card.style.display = (world === 'all' || card.dataset.world === world) ? '' : 'none';
    });
    syncUrl();
  }

  worldTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      worldTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      applyWorldFilter(tab.dataset.world || 'all');
    });
  });

  // --- 3. Date Scrubber ---
  const scrubber = document.getElementById('scrubber');
  const thumb = document.getElementById('scrubberThumb');
  const label = document.getElementById('scrubberLabel');

  if (scrubber && thumb && label && timeline) {
    const TRACK_TOP = 10;
    const TRACK_BOTTOM = 10;
    let hideTimer: ReturnType<typeof setTimeout>;
    let isDragging = false;

    function trackRange() {
      const vh = window.innerHeight;
      const top = vh * TRACK_TOP / 100;
      const bottom = vh - vh * TRACK_BOTTOM / 100;
      return { top, bottom, range: bottom - top };
    }

    function scrollFraction() {
      const max = timeline.scrollHeight - timeline.clientHeight;
      return max > 0 ? timeline.scrollTop / max : 0;
    }

    function currentDateLabel() {
      const mid = timeline.scrollTop + timeline.clientHeight / 2;
      let closest: HTMLElement | null = null;
      let closestDist = Infinity;
      for (const s of slides) {
        if (s.style.display === 'none') continue;
        const dist = Math.abs((s as HTMLElement).offsetTop + (s as HTMLElement).offsetHeight / 2 - mid);
        if (dist < closestDist) { closestDist = dist; closest = s as HTMLElement; }
      }
      if (!closest?.dataset.date) return '';
      const d = new Date(closest.dataset.date);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
    }

    function positionThumb() {
      const { top, range } = trackRange();
      const y = top + scrollFraction() * range;
      thumb.style.top = `${y}px`;
      label.style.top = `${y}px`;
      label.textContent = currentDateLabel();
    }

    function showScrubber() {
      scrubber.classList.add('visible');
      clearTimeout(hideTimer);
      if (!isDragging) {
        hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 2000);
      }
    }

    timeline.addEventListener('scroll', () => {
      positionThumb();
      showScrubber();
    }, { passive: true });

    scrubber.addEventListener('mouseenter', showScrubber);
    scrubber.addEventListener('mouseleave', () => {
      if (!isDragging) {
        hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 800);
      }
    });

    function scrubTo(clientY: number) {
      const { top, range } = trackRange();
      const frac = Math.max(0, Math.min(1, (clientY - top) / range));
      const max = timeline.scrollHeight - timeline.clientHeight;
      timeline.scrollTop = frac * max;
    }

    scrubber.addEventListener('mousedown', (e) => {
      isDragging = true;
      scrubber.classList.add('dragging');
      scrubTo(e.clientY);
      showScrubber();
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      scrubTo(e.clientY);
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      scrubber.classList.remove('dragging');
      hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 2000);
    });

    positionThumb();
  }

  // --- 4. Keyboard navigation ---
  function currentSlideIndex(): number {
    const mid = timeline.scrollTop + timeline.clientHeight / 2;
    let closest = 0;
    let closestDist = Infinity;
    const visible = Array.from(slides).filter(s => s.style.display !== 'none');
    visible.forEach((s, i) => {
      const dist = Math.abs(s.offsetTop + s.offsetHeight / 2 - mid);
      if (dist < closestDist) { closestDist = dist; closest = i; }
    });
    return closest;
  }

  let keyNavTarget = -1;
  let keyLocked = false;
  let keySettleTimer: ReturnType<typeof setTimeout>;
  const KEY_RATE = 200;

  document.addEventListener('keydown', (e) => {
    if (document.querySelector('.lightbox')) return;
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
    e.preventDefault();

    if (e.repeat && keyLocked) return;

    const visible = Array.from(slides).filter(s => s.style.display !== 'none');
    if (!visible.length) return;

    const current = keyNavTarget >= 0 ? keyNavTarget : currentSlideIndex();
    const next = e.key === 'ArrowDown'
      ? Math.min(current + 1, visible.length - 1)
      : Math.max(current - 1, 0);

    keyNavTarget = next;
    clearTimeout(keySettleTimer);

    if (e.repeat) {
      keyLocked = true;
      setTimeout(() => { keyLocked = false; }, KEY_RATE);
      timeline.style.scrollSnapType = 'none';
      timeline.scrollTop = visible[next].offsetTop;
      keySettleTimer = setTimeout(() => {
        timeline.style.scrollSnapType = '';
        keyNavTarget = -1;
      }, 350);
    } else {
      visible[next].scrollIntoView({ behavior: 'smooth' });
      keySettleTimer = setTimeout(() => { keyNavTarget = -1; }, 500);
    }
  });

  // --- 5. Hash-based deep linking ---
  const slideObserver = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting && entry.target.id) {
        history.replaceState(null, '', `#${entry.target.id}`);
        break;
      }
    }
  }, { root: timeline, threshold: 0.6 });

  slides.forEach((s) => { if (s.id) slideObserver.observe(s); });

  if (location.hash) {
    const target = document.getElementById(location.hash.slice(1));
    if (target) {
      requestAnimationFrame(() => {
        target.scrollIntoView({ behavior: 'instant' });
      });
    }
  }

  // --- 6. View Toggle (Timeline / Catalog) ---
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
  const catalogEl = document.getElementById('catalog');

  function switchView(view: string) {
    currentView = view;
    viewBtns.forEach(b => b.classList.remove('active'));
    viewBtns.forEach(b => { if (b.dataset.view === view) b.classList.add('active'); });
    if (view === 'catalog') {
      timeline.style.display = 'none';
      scrubber?.style.setProperty('display', 'none');
      if (catalogEl) catalogEl.style.display = '';
    } else {
      timeline.style.display = '';
      scrubber?.style.removeProperty('display');
      if (catalogEl) catalogEl.style.display = 'none';
    }
    syncUrl();
  }

  viewBtns.forEach((btn) => {
    btn.addEventListener('click', () => switchView(btn.dataset.view || 'timeline'));
  });

  // --- 7. Restore state from URL params ---
  const initParams = new URLSearchParams(location.search);
  const initWorld = initParams.get('world') || 'all';
  const initView = initParams.get('view') || 'timeline';

  if (initWorld !== 'all') {
    worldTabs.forEach(t => {
      t.classList.toggle('active', t.dataset.world === initWorld);
    });
    applyWorldFilter(initWorld);
  }

  if (initView === 'catalog') {
    switchView('catalog');
  }

</script>

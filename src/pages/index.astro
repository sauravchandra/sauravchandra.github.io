---
import Base from '../layouts/Base.astro';
import TimelineItem from '../components/TimelineItem.astro';
import type { TimelineEntry } from '../components/TimelineItem.astro';
import { getCollection, render } from 'astro:content';

const feed: TimelineEntry[] = [];

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
for (const p of allPosts) {
  const { Content } = await render(p);
  let html = '';
  try {
    const result = await Astro.slots.render('default');
    html = result;
  } catch {}
  feed.push({
    title: p.data.title, description: p.data.description,
    date: p.data.date, world: p.data.world, source: 'post',
    url: `/${p.id}/`, external: false, image: p.data.cover,
    meta: { tags: p.data.tags, _Content: Content },
  });
}

const ytVideos = await getCollection('youtube');
for (const v of ytVideos) {
  feed.push({
    title: v.data.caption, date: v.data.date, world: 'film',
    source: 'youtube', url: `https://youtube.com/watch?v=${v.data.videoId}`,
    external: true, image: v.data.thumbnail,
    meta: { videoId: v.data.videoId },
  });
}

const carouselSlides = await getCollection('carousel');
for (const c of carouselSlides) {
  feed.push({
    title: c.data.caption, date: c.data.date, world: 'travel',
    source: 'carousel', url: '#', external: false, image: c.data.image,
  });
}

const lbEntries = await getCollection('letterboxd');
for (const lb of lbEntries) {
  feed.push({
    title: lb.data.filmTitle, description: lb.data.review,
    date: lb.data.date, world: 'film', source: 'letterboxd',
    url: lb.data.url, external: true, image: lb.data.poster,
    meta: { rating: lb.data.rating },
  });
}

const ssEntries = await getCollection('substackFeed');
for (const s of ssEntries) {
  feed.push({
    title: s.data.title, description: s.data.excerpt,
    date: s.data.date, world: 'philosophy', source: 'substack',
    url: s.data.url, external: true,
  });
}

const mdEntries = await getCollection('mediumFeed');
for (const m of mdEntries) {
  feed.push({
    title: m.data.title, description: m.data.excerpt,
    date: m.data.date, world: 'philosophy', source: 'medium',
    url: m.data.url, external: true,
  });
}

const ghRepos = await getCollection('github');
for (const r of ghRepos) {
  feed.push({
    title: r.data.name, description: r.data.description,
    date: r.data.date, world: 'tech', source: 'github',
    url: r.data.url, external: true,
    meta: { language: r.data.language, stars: r.data.stars },
  });
}

const scTracks = await getCollection('soundcloud');
for (const t of scTracks) {
  feed.push({
    title: t.data.trackTitle, date: t.data.date, world: 'music',
    source: 'soundcloud', url: t.data.url, external: true,
    image: t.data.artwork,
  });
}

const spEntries = await getCollection('spotify');
for (const sp of spEntries) {
  feed.push({
    title: sp.data.name, date: new Date(), world: 'music',
    source: 'spotify', url: sp.data.url, external: true,
    image: sp.data.image,
    meta: { embedUrl: sp.data.embedUrl },
  });
}

const galEntries = await getCollection('gallery');
for (const g of galEntries) {
  feed.push({
    title: g.data.title, description: g.data.location,
    date: g.data.date, world: 'travel', source: 'gallery',
    url: `/gallery/${g.id}/`, external: false, image: g.data.cover,
    meta: { photos: g.data.photos },
  });
}

feed.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Base isTimeline>
  <div class="timeline" id="timeline">
    {feed.map((item) => {
      if (item.source === 'post' && item.meta?._Content) {
        const PostContent = item.meta._Content;
        const postItem = { ...item, meta: { ...item.meta, _Content: undefined } };
        return (
          <div class:list={['tl-slide', 'slide-post']} data-world={item.world} data-source="post" data-date={item.date.toISOString()}>
            <div class="slide-hero">
              {item.image && (
                <div class="slide-bg">
                  <img src={item.image} alt={item.title} loading="lazy" />
                </div>
              )}
              {!item.image && (
                <div class="slide-bg" style={`background: linear-gradient(135deg, var(--${item.world}) 0%, #111 100%);`}></div>
              )}
              <div class="slide-overlay">
                <div class="slide-meta">
                  <span class="slide-world" style={`--accent: var(--${item.world})`}>{item.world.charAt(0).toUpperCase() + item.world.slice(1)}</span>
                  <span class="slide-date">{item.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                </div>
                <h2 class="slide-title">{item.title}</h2>
                {item.description && <p class="slide-desc">{item.description}</p>}
              </div>
              <div class="slide-scroll-hint">
                <span>Scroll to read</span>
                <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2"/></svg>
              </div>
            </div>
            <div class="slide-post-body">
              {item.meta?.tags && (
                <div class="slide-post-tags">
                  {(item.meta.tags as string[]).map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              )}
              <div class="prose">
                <PostContent />
              </div>
            </div>
          </div>
        );
      }
      return <TimelineItem item={item} />;
    })}

    {feed.length === 0 && (
      <div class="tl-slide slide-empty-state" style="display:flex;align-items:center;justify-content:center;">
        <p class="slide-empty">Nothing here yet.</p>
      </div>
    )}
  </div>

  <!-- Edge arrows -->
  <button class="edge-arrow edge-arrow-left" id="arrowLeft" aria-label="Previous">
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="edge-arrow edge-arrow-right visible" id="arrowRight" aria-label="Next">
    <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
  </button>

  <!-- Bottom scrubber -->
  <div class="scrubber" id="scrubber">
    <div class="scrubber-track"></div>
    <div class="scrubber-thumb" id="scrubberThumb"></div>
    <div class="scrubber-label" id="scrubberLabel"></div>
  </div>
</Base>

<script>
  const timeline = document.getElementById('timeline');
  if (!timeline) throw new Error('missing timeline');

  const allSlides = Array.from(document.querySelectorAll<HTMLElement>('.tl-slide'));
  let visibleSlides = allSlides.slice();

  function currentSlideIndex(): number {
    const sl = timeline.scrollLeft;
    const vw = window.innerWidth;
    return Math.round(sl / vw);
  }

  function goToSlide(idx: number) {
    const clamped = Math.max(0, Math.min(idx, visibleSlides.length - 1));
    visibleSlides[clamped]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
  }

  // --- 1. Video Observer ---
  const videoSlides = document.querySelectorAll<HTMLElement>('.slide-video');

  const videoObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const el = entry.target as HTMLElement;
      const iframe = el.querySelector('iframe') as HTMLIFrameElement | null;
      if (!iframe) return;
      if (entry.isIntersecting) {
        if (!iframe.src) iframe.src = iframe.dataset.src || '';
      } else {
        if (iframe.src) iframe.src = '';
      }
    });
  }, { root: timeline, threshold: 0.5 });

  videoSlides.forEach((v) => videoObserver.observe(v));

  document.querySelectorAll<HTMLButtonElement>('.slide-mute-btn').forEach((btn) => {
    let muted = true;
    btn.addEventListener('click', () => {
      const iframe = btn.closest('.tl-slide')?.querySelector('iframe') as HTMLIFrameElement | null;
      if (!iframe?.contentWindow) return;
      muted = !muted;
      iframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: muted ? 'mute' : 'unMute' }), '*');
      const iconM = btn.querySelector('.icon-muted') as HTMLElement;
      const iconU = btn.querySelector('.icon-unmuted') as HTMLElement;
      if (iconM) iconM.style.display = muted ? 'block' : 'none';
      if (iconU) iconU.style.display = muted ? 'none' : 'block';
      btn.setAttribute('aria-label', muted ? 'Unmute' : 'Mute');
    });
  });

  // --- 2. Gallery lightbox ---
  document.querySelectorAll('[data-gallery]').forEach((grid) => {
    const imgs = Array.from(grid.querySelectorAll('img'));
    imgs.forEach((img, idx) => {
      img.addEventListener('click', () => openLightbox(imgs.map(i => i.src), idx));
    });
  });

  function openLightbox(srcs: string[], startIdx: number) {
    let idx = startIdx;
    const lb = document.createElement('div');
    lb.className = 'lightbox';
    lb.innerHTML = `
      <button class="lightbox-close">&times;</button>
      <button class="lightbox-prev">&lsaquo;</button>
      <img src="${srcs[idx]}" alt="">
      <button class="lightbox-next">&rsaquo;</button>
      <div class="lightbox-counter">${idx + 1} / ${srcs.length}</div>
    `;
    document.body.appendChild(lb);

    const imgEl = lb.querySelector('img')!;
    const counterEl = lb.querySelector('.lightbox-counter')!;
    const update = () => { imgEl.src = srcs[idx]; counterEl.textContent = `${idx + 1} / ${srcs.length}`; };

    lb.querySelector('.lightbox-close')!.addEventListener('click', () => lb.remove());
    lb.querySelector('.lightbox-prev')!.addEventListener('click', () => { idx = (idx - 1 + srcs.length) % srcs.length; update(); });
    lb.querySelector('.lightbox-next')!.addEventListener('click', () => { idx = (idx + 1) % srcs.length; update(); });
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.remove(); });
    document.addEventListener('keydown', function handler(e) {
      if (e.key === 'Escape') { lb.remove(); document.removeEventListener('keydown', handler); }
      if (e.key === 'ArrowLeft') { idx = (idx - 1 + srcs.length) % srcs.length; update(); }
      if (e.key === 'ArrowRight') { idx = (idx + 1) % srcs.length; update(); }
    });
  }

  // --- 3. Edge arrows ---
  const arrowLeft = document.getElementById('arrowLeft');
  const arrowRight = document.getElementById('arrowRight');

  function updateArrows() {
    const idx = currentSlideIndex();
    arrowLeft?.classList.toggle('visible', idx > 0);
    arrowRight?.classList.toggle('visible', idx < visibleSlides.length - 1);
  }

  arrowLeft?.addEventListener('click', () => goToSlide(currentSlideIndex() - 1));
  arrowRight?.addEventListener('click', () => goToSlide(currentSlideIndex() + 1));

  // --- 4. Keyboard navigation ---
  document.addEventListener('keydown', (e) => {
    if (document.querySelector('.lightbox')) return;
    if (e.key === 'ArrowLeft') { e.preventDefault(); goToSlide(currentSlideIndex() - 1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); goToSlide(currentSlideIndex() + 1); }
  });

  // --- 5. Wheel overflow: scroll past content edge → next/prev slide ---
  allSlides.forEach((slide) => {
    let wheelAccum = 0;
    let wheelTimer: ReturnType<typeof setTimeout>;
    const THRESHOLD = 120;

    slide.addEventListener('wheel', (e) => {
      const atTop = slide.scrollTop <= 0;
      const atBottom = slide.scrollTop + slide.clientHeight >= slide.scrollHeight - 2;
      const isVertical = Math.abs(e.deltaY) > Math.abs(e.deltaX);

      if (isVertical && slide.scrollHeight > slide.clientHeight + 10) {
        if ((e.deltaY < 0 && atTop) || (e.deltaY > 0 && atBottom)) {
          wheelAccum += e.deltaY;
          clearTimeout(wheelTimer);
          wheelTimer = setTimeout(() => { wheelAccum = 0; }, 300);

          if (Math.abs(wheelAccum) > THRESHOLD) {
            const idx = currentSlideIndex();
            goToSlide(wheelAccum > 0 ? idx + 1 : idx - 1);
            wheelAccum = 0;
          }
          e.preventDefault();
        } else {
          wheelAccum = 0;
        }
      } else if (isVertical && slide.scrollHeight <= slide.clientHeight + 10) {
        wheelAccum += e.deltaY;
        clearTimeout(wheelTimer);
        wheelTimer = setTimeout(() => { wheelAccum = 0; }, 300);

        if (Math.abs(wheelAccum) > THRESHOLD) {
          const idx = currentSlideIndex();
          goToSlide(wheelAccum > 0 ? idx + 1 : idx - 1);
          wheelAccum = 0;
        }
        e.preventDefault();
      }
    }, { passive: false });
  });

  // --- 6. Filter + Counter ---
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const counter = document.getElementById('navCounter');

  function updateCounter() {
    if (counter) {
      const idx = currentSlideIndex();
      counter.textContent = `${idx + 1} / ${visibleSlides.length}`;
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      allSlides.forEach((slide) => {
        const show = filter === 'all' || slide.dataset.world === filter;
        slide.style.display = show ? '' : 'none';
      });
      visibleSlides = allSlides.filter(s => s.style.display !== 'none');
      if (visibleSlides.length > 0) {
        visibleSlides[0].scrollIntoView({ behavior: 'instant', block: 'nearest', inline: 'start' });
      }
      updateCounter();
      updateArrows();
    });
  });

  // --- 7. Horizontal scrubber ---
  const scrubber = document.getElementById('scrubber');
  const thumb = document.getElementById('scrubberThumb');
  const label = document.getElementById('scrubberLabel');

  if (scrubber && thumb && label) {
    const TRACK_LEFT = 10;
    const TRACK_RIGHT = 10;
    let hideTimer: ReturnType<typeof setTimeout>;
    let isDragging = false;

    function trackRange() {
      const vw = window.innerWidth;
      const left = vw * TRACK_LEFT / 100;
      const right = vw - vw * TRACK_RIGHT / 100;
      return { left, right, range: right - left };
    }

    function scrollFraction() {
      const max = timeline.scrollWidth - timeline.clientWidth;
      return max > 0 ? timeline.scrollLeft / max : 0;
    }

    function currentDateLabel() {
      const idx = currentSlideIndex();
      const slide = visibleSlides[idx];
      if (!slide?.dataset.date) return '';
      const d = new Date(slide.dataset.date);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
    }

    function positionThumb() {
      const { left, range } = trackRange();
      const x = left + scrollFraction() * range;
      thumb.style.left = `${x}px`;
      label.style.left = `${x}px`;
      label.textContent = currentDateLabel();
    }

    function showScrubber() {
      scrubber.classList.add('visible');
      clearTimeout(hideTimer);
      if (!isDragging) {
        hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 2000);
      }
    }

    timeline.addEventListener('scroll', () => {
      positionThumb();
      showScrubber();
      updateCounter();
      updateArrows();
    }, { passive: true });

    scrubber.addEventListener('mouseenter', showScrubber);
    scrubber.addEventListener('mouseleave', () => {
      if (!isDragging) {
        hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 800);
      }
    });

    function scrubTo(clientX: number) {
      const { left, range } = trackRange();
      const frac = Math.max(0, Math.min(1, (clientX - left) / range));
      const max = timeline.scrollWidth - timeline.clientWidth;
      timeline.scrollLeft = frac * max;
    }

    scrubber.addEventListener('mousedown', (e) => {
      isDragging = true;
      scrubber.classList.add('dragging');
      scrubTo(e.clientX);
      showScrubber();
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      scrubTo(e.clientX);
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      scrubber.classList.remove('dragging');
      hideTimer = setTimeout(() => scrubber.classList.remove('visible'), 2000);
    });

    positionThumb();
  }

  updateCounter();
  updateArrows();
</script>
